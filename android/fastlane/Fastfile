default_platform(:android)

platform :android do

  # ── Build ──────────────────────────────────────────────────────────────────
  # Builds a signed AAB ready for Play Store upload.
  # Called by the 'deploy' lane, or run standalone for a local build check.
  desc "Build a signed release AAB"
  lane :build do
    gradle(
      project_dir: ".",
      task:        "bundle",
      build_type:  "Release",
      properties: {
        "android.injected.signing.store.file"     => ENV["KEYSTORE_PATH"],
        "android.injected.signing.store.password" => ENV["KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias"      => ENV["KEY_ALIAS"],
        "android.injected.signing.key.password"   => ENV["KEY_PASSWORD"],
      }
    )
  end

  # ── Deploy ─────────────────────────────────────────────────────────────────
  # Builds a signed AAB and uploads it to the Play Store internal testing track.
  # Promote to alpha/beta/production manually in the Play Console.
  desc "Build and upload to Play Store internal track"
  lane :deploy do
    build

    upload_to_play_store(
      track:              "internal",
      release_status:     "draft",
      aab:                lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH],
      skip_upload_apk:    true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  # ── Promote ────────────────────────────────────────────────────────────────
  # Promotes the latest internal build to production (100% rollout).
  # Run manually after QA sign-off: fastlane android promote
  desc "Promote internal build to production"
  lane :promote do
    upload_to_play_store(
      track:        "internal",
      track_promote_to: "production",
      rollout:      "1.0",
      skip_upload_aab:         true,
      skip_upload_apk:         true,
      skip_upload_images:      true,
      skip_upload_screenshots: true,
    )
  end

end

