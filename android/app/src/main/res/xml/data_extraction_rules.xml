<?xml version="1.0" encoding="utf-8"?>
<!-- Squigglebug stores no user data — disable all cloud and device-to-device backup. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
